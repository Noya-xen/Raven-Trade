  "version": "1.0.0",
  "description": "Auto trade bot for Raven Market using Loop SDK",
  "main": "dist/index.js",
  "scripts": {
    "build": "esbuild index.ts --bundle --platform=node --target=node16 --outdir=dist --format=cjs",
